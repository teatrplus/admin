# PocketBase reads hook env vars from the host environment (systemd, Docker, etc.).
# PocketBase does not auto-load this file.

# -----------------------------------------------------------------------------
# Google Workspace SMTP relay (no app password)
# Configure in PocketBase Admin → Settings → Mail settings:
#
#   Host: smtp-relay.gmail.com
#   Port: 587
#   Encryption: TLS / STARTTLS
#   Username: (leave empty when using IP allowlisting)
#   Password: (leave empty when using IP allowlisting)
#   EHLO/HELO domain (localName): theaterplus.uz
#     Use your primary sending domain — not localhost, not smtp-relay.gmail.com.
#     A hostname you control (e.g. pb.theaterplus.uz) also works if it has matching PTR.
#   Sender address: adm@theaterplus.uz  (or an alias on that account, e.g. info@)
#   Sender name: Teatr Plus
#
# Google Admin Console → Apps → Google Workspace → Gmail → Routing
# → SMTP relay service:
#   - Allowed senders: Only addresses in my domains
#   - Authentication: Only accept mail from the specified IP addresses
#     → add your PocketBase server's public IP
#   - Encryption: Require TLS encryption
#
# If your relay rule also requires SMTP AUTH, use adm@theaterplus.uz + that account's
# app password (only if your org allows it). IP-only relay is the usual path when
# app passwords are disabled.
# -----------------------------------------------------------------------------

# Inbox for new space landing requests
SPACE_REQUEST_NOTIFY_EMAIL=info@teatrplus.uz

# Optional deep link in email / Telegram (no trailing slash)
ADMIN_APP_URL=https://admin.theaterplus.uz

# Theater bot — must be an admin in the private channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Cloudflare deploy hook - triggers SSG rebuild when CMS content changes
CLOUDFLARE_PAGES_DEPLOY_HOOK_URL=

# Queue cleanup: drop stale queued deploy-hook builds before triggering a new one.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT_NAME=landing
CLOUDFLARE_API_TOKEN=
